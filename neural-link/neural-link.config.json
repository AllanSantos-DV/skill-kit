{
  "version": "1.0",
  "registration": "manual",
  "debug": true,
  "threshold": 0.5,
  "defaultTimeout": 5000,
  "eventTimeouts": {
    "Stop": 12000
  },
  "learning": {
    "lambda": 0.4,
    "defaultWeight": 0.55,
    "enableDefaultWeight": true,
    "learningRate": 0.01,
    "minActivations": 20,
    "floors": {
      "pre-commit-guard": 0.8
    },
    "ceilings": {},
    "llmFallback": {
      "enabled": false,
      "margin": 0.1,
      "timeout": 2000,
      "adjustment": 0.1,
      "endpoint": null,
      "model": null,
      "apiKey": null
    }
  },
  "handlers": {
    "pre-commit-guard": {
      "enabled": true,
      "events": ["PreToolUse"],
      "script": {
        "node": "~/.copilot/hooks/pre-commit-guard.js"
      },
      "timeout": 5000,
      "threshold": null,
      "weight": 0.95,
      "modifiers": [
        {
          "condition": "tool_name == 'run_in_terminal' && command_matches('git (push|tag|reset\\s+--hard|rebase|force-push)')",
          "adjust": "+0.05"
        },
        {
          "condition": "tool_name == 'run_in_terminal' && command_matches('rm\\s+-(r|rf|fr)|rmdir\\s+/s|del\\s+/s|format\\s+|mkfs')",
          "adjust": "+0.05"
        },
        {
          "condition": "tool_name != 'run_in_terminal'",
          "adjust": "=0.0"
        }
      ]
    },
    "stop-checklist": {
      "enabled": true,
      "events": ["Stop", "SubagentStop"],
      "routing": {
        "skipWhen": [
          { "hookEventName": "Stop" }
        ]
      },
      "script": {
        "node": "~/.copilot/hooks/stop-checklist.js"
      },
      "timeout": 10000,
      "threshold": null,
      "weight": 0.7,
      "modifiers": []
    },
    "verify-claims": {
      "enabled": true,
      "events": ["Stop"],
      "script": {
        "node": "~/.copilot/hooks/verify-claims.js"
      },
      "timeout": 5000,
      "threshold": null,
      "weight": 0.9,
      "modifiers": [
        {
          "condition": "transcript_has_file_references == false",
          "adjust": "=0.3"
        }
      ]
    },
    "context-confidence-check": {
      "enabled": true,
      "events": ["Stop"],
      "script": {
        "node": "~/.copilot/hooks/context-confidence-check.js"
      },
      "timeout": 10000,
      "threshold": null,
      "weight": 0.85,
      "modifiers": [
        {
          "condition": "transcript_has_confidence_table == false",
          "adjust": "=0.0"
        }
      ]
    },
    "output-format": {
      "enabled": true,
      "events": ["Stop", "SubagentStop"],
      "routing": {
        "skipWhen": [
          { "hookEventName": "Stop" }
        ]
      },
      "script": {
        "node": "~/.copilot/hooks/output-format.js"
      },
      "timeout": 10000,
      "threshold": null,
      "weight": 0.7,
      "modifiers": []
    },
    "skill-feedback": {
      "enabled": true,
      "events": ["Stop"],
      "script": {
        "node": "~/.copilot/hooks/skill-feedback.js"
      },
      "timeout": 5000,
      "threshold": null,
      "weight": 0.8,
      "modifiers": [
        {
          "condition": "transcript_has_skill_read == false",
          "adjust": "=0.0"
        }
      ]
    },
    "subagent-audit": {
      "enabled": true,
      "events": ["SubagentStart"],
      "script": {
        "node": "~/.copilot/hooks/subagent-audit.js"
      },
      "timeout": 5000,
      "threshold": null,
      "weight": 0.9,
      "modifiers": []
    },
    "lesson-injector": {
      "enabled": true,
      "events": ["UserPromptSubmit"],
      "script": {
        "node": "~/.copilot/hooks/lesson-injector.js"
      },
      "timeout": 5000,
      "threshold": null,
      "weight": 0.85,
      "modifiers": [
        {
          "condition": "active_skills_include('safety-check')",
          "adjust": "+0.1"
        }
      ]
    }
  }
}
