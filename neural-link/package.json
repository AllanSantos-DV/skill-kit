{
  "name": "neural-link",
  "version": "0.1.0",
  "private": true,
  "description": "Adaptive hook dispatcher for LLM agents",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "node --test tests/dispatcher.test.js tests/learning.test.js tests/security.test.js",
    "test:e2e": "node tests/e2e-guard.mjs && node tests/e2e-pretrain.mjs --rounds 10",
    "test:validate": "node tests/e2e-validate.mjs --rounds 100",
    "test:real": "node tests/e2e-real-dispatch.mjs",
    "test:traffic": "node tests/e2e-real-traffic.mjs",
    "test:all": "npm test && npm run test:e2e && npm run test:real",
    "lint": "eslint src/ tests/",
    "start": "node src/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0"
  }
}
