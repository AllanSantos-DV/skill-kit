{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks-scripts/session-context.sh",
            "command_win32": "powershell -ExecutionPolicy Bypass -File \"$HOME\\.claude\\hooks-scripts\\session-context.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks-scripts/pre-commit-guard.sh",
            "command_win32": "powershell -ExecutionPolicy Bypass -File \"$HOME\\.claude\\hooks-scripts\\pre-commit-guard.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks-scripts/output-format.sh",
            "command_win32": "powershell -ExecutionPolicy Bypass -File \"$HOME\\.claude\\hooks-scripts\\output-format.ps1\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks-scripts/stop-checklist.sh",
            "command_win32": "powershell -ExecutionPolicy Bypass -File \"$HOME\\.claude\\hooks-scripts\\stop-checklist.ps1\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks-scripts/verify-claims.sh",
            "command_win32": "powershell -ExecutionPolicy Bypass -File \"$HOME\\.claude\\hooks-scripts\\verify-claims.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks-scripts/subagent-audit.sh",
            "command_win32": "powershell -ExecutionPolicy Bypass -File \"$HOME\\.claude\\hooks-scripts\\subagent-audit.ps1\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
