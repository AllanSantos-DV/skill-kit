{
  "handler": "context-confidence-check",
  "events": ["Stop"],
  "weights": {
    "researcher": 0.9,
    "validator": 0.9,
    "implementor": 0.5,
    "orchestrator": 0.3
  },
  "modifiers": [
    {
      "condition": { "field": "transcript_has_confidence_table", "op": "eq", "value": false },
      "adjust": "=0.0"
    }
  ],
  "trainingScenarios": [
    {
      "input": {
        "event": "Stop",
        "agentSlug": "researcher"
      },
      "mockResults": [
        { "handler": "context-confidence-check", "action": "block", "reason": "Confidence table has uncertain axes without tool evidence. Axis 'Dependencies' (🟡) has empty Tools used column." }
      ],
      "label": "should block when confidence table missing tool evidence for uncertain axes"
    },
    {
      "input": {
        "event": "Stop",
        "agentSlug": "validator"
      },
      "mockResults": [
        { "handler": "context-confidence-check", "action": "allow" }
      ],
      "label": "should allow when all confidence axes are green or have tool evidence"
    },
    {
      "input": {
        "event": "Stop",
        "agentSlug": "implementor"
      },
      "mockResults": [
        { "handler": "context-confidence-check", "action": "allow" }
      ],
      "label": "should allow when no confidence table present (modifier zeros score)"
    }
  ]
}
