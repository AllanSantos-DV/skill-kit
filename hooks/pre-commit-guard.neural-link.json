{
  "handler": "pre-commit-guard",
  "events": ["PreToolUse"],
  "weights": {
    "implementor": 0.9,
    "orchestrator": 0.2,
    "researcher": 0.1,
    "validator": 0.1
  },
  "modifiers": [
    {
      "condition": { "field": "tool_name", "op": "in", "value": ["run_in_terminal"] },
      "adjust": "+0.1"
    },
    {
      "condition": { "field": "tool_name", "op": "notIn", "value": ["run_in_terminal"] },
      "adjust": "=0.0"
    }
  ],
  "trainingScenarios": [
    {
      "input": {
        "event": "PreToolUse",
        "agentSlug": "implementor",
        "tool": "run_in_terminal",
        "payload": { "command": "git push --force origin main", "isBackground": false }
      },
      "mockResults": [
        { "handler": "pre-commit-guard", "action": "block", "reason": "Blocked: git push --force (destructive, rewrites remote history)" }
      ],
      "label": "should block force push from implementor"
    },
    {
      "input": {
        "event": "PreToolUse",
        "agentSlug": "implementor",
        "tool": "run_in_terminal",
        "payload": { "command": "rm -rf /tmp/build", "isBackground": false }
      },
      "mockResults": [
        { "handler": "pre-commit-guard", "action": "block", "reason": "Blocked: destructive filesystem command" }
      ],
      "label": "should block destructive rm -rf"
    },
    {
      "input": {
        "event": "PreToolUse",
        "agentSlug": "implementor",
        "tool": "run_in_terminal",
        "payload": { "command": "git status", "isBackground": false }
      },
      "mockResults": [
        { "handler": "pre-commit-guard", "action": "allow" }
      ],
      "label": "should allow safe git status"
    },
    {
      "input": {
        "event": "PreToolUse",
        "agentSlug": "implementor",
        "tool": "read_file",
        "payload": { "filePath": "src/index.ts" }
      },
      "mockResults": [
        { "handler": "pre-commit-guard", "action": "allow" }
      ],
      "label": "should allow non-terminal tools (modifier zeros score)"
    }
  ]
}
